# ===========================================
# Xine by Unisource - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# --- Option A: Self-Hosted PostgreSQL (Docker/VPS) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=analytics_db

# --- Option B: Cloud PostgreSQL (Supabase, Neon, Railway) ---
# DATABASE_URL=postgresql://user:password@host:5432/database
# STANDALONE_OUTPUT=false

# Dashboard Authentication
# Used to protect the /dashboard route
DASHBOARD_PASSWORD=your_secure_password

# Cloudflare (Optional - for cache purging on deploy)
# CF_API_TOKEN=your_cloudflare_api_token
# CF_ZONE_ID=your_cloudflare_zone_id
