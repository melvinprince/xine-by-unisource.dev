# ===========================================
# Xine by Unisource - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# --- Option A: Self-Hosted PostgreSQL (Docker/VPS) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=analytics_db

# --- Option B: Cloud PostgreSQL (Supabase, Neon, Railway) ---
# DATABASE_URL=postgresql://user:password@host:5432/database
# STANDALONE_OUTPUT=false
# DB_SSL_REJECT_UNAUTHORIZED=true  # Set to 'false' only for development with self-signed certs

# Dashboard Authentication
# Used to protect the /dashboard route
DASHBOARD_PASSWORD=your_secure_password

# (Recommended) Bcrypt hash of your password — more secure than plaintext.
# Generate with: node -e "console.log(require('bcryptjs').hashSync('your_password', 10))"
# If set, DASHBOARD_PASSWORD is still needed as a fallback but the hash is preferred.
# DASHBOARD_PASSWORD_HASH=$2a$10$...your_bcrypt_hash_here...

# Session Signing Secret (RECOMMENDED)
# A separate secret for HMAC session token signing.
# If not set, falls back to DASHBOARD_PASSWORD.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SESSION_SECRET=your_random_64_char_hex_string

# Cron Job Authentication (REQUIRED for /api/cron/* endpoints)
# Set this to protect cron routes from unauthorized access.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your_cron_secret_here

# Cloudflare (Optional - for cache purging on deploy)
# CF_API_TOKEN=your_cloudflare_api_token
# CF_ZONE_ID=your_cloudflare_zone_id
